# Database (Supabase PostgreSQL)
DATABASE_URL=

# JWT (optionnel si vous n'utilisez que Supabase Auth + JWKS)
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Supabase — Identity Provider (vérification JWT via JWKS)
SUPABASE_PROJECT_ID=
SUPABASE_JWT_AUDIENCE=authenticated

# Redis (Bull queue)
REDIS_URL=rediss://default:<password>@<host>:6379

# Twilio (WhatsApp) — préparation future
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Application
PORT=3000
APP_BASE_URL=http://localhost:3000

# ── Simulation paiement (dev/test uniquement) ──
# Clé requise pour appeler PATCH /reservations/:id/confirm-payment
# En production ce endpoint est remplacé par les webhooks Wave/Orange Money
INTERNAL_API_KEY=change-me-in-production

# ── Wave CI ──
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
WAVE_API_URL=https://api.sandbox.wave.com/v1

# ── Orange Money ──
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_WEBHOOK_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Resend) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@autoloc.sn

# ── Telegram Admin Alerts ──
# 1. Crée un bot via @BotFather → copie le token
# 2. Ajoute le bot à ton groupe/canal admin, envoie un message
# 3. GET https://api.telegram.org/bot<TOKEN>/getUpdates → copie chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

NEXTJS_URL=http://localhost:3000
REVALIDATE_SECRET=super_secret_revalidate_token_123
